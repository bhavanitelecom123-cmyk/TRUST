generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String?       // Nullable for OAuth-only and OTP-only accounts
  googleId       String?       @unique
  emailVerified  DateTime?
  image          String?
  role           Role          @default(USER)
  createdBy      String?       @map("created_by")
  createdAt      DateTime      @default(now())
  comments       Comment[]
  family         Family?
  learnFolders   LearnFolder[]
  learnPosts     LearnPost[]
  likes          Like[]
  posts          Post[]
  creator        User?         @relation("CreatedUsers", fields: [createdBy], references: [id])
  createdUsers   User[]       @relation("CreatedUsers")

  @@map("users")
}

model Person {
  id                  String         @id @default(cuid())
  firstName           String
  middleName          String?
  lastName            String
  gender              String
  dateOfBirth         DateTime?
  isDeceased          Boolean        @default(false)
  createdAt           DateTime       @default(now())
  child               Child?
  fatherOf            Family[]       @relation("FatherPerson")
  headOfFamily        Family?        @relation("HeadPerson")
  motherOf            Family[]       @relation("MotherPerson")
  children            Relationship[] @relation("ChildRelationship")
  parentRelationships Relationship[] @relation("ParentRelationship")
  spouse              Spouse?

  @@index([firstName])
  @@index([lastName])
  @@index([firstName, lastName])
  @@map("persons")
}

model Relationship {
  id           String       @id @default(cuid())
  parentId     String
  childId      String
  relationType RelationType
  createdAt    DateTime     @default(now())
  child        Person       @relation("ChildRelationship", fields: [childId], references: [id])
  parent       Person       @relation("ParentRelationship", fields: [parentId], references: [id])

  @@unique([parentId, childId, relationType])
  @@index([parentId])
  @@index([childId])
  @@index([relationType])
  @@map("relationships")
}

model Family {
  id                 String       @id @default(cuid())
  userId             String       @unique
  firstName          String
  middleName         String?
  lastName           String
  headPersonId       String?      @unique
  fatherFirstName    String?
  fatherMiddleName   String?
  fatherLastName     String?
  fatherId           String?
  motherFirstName    String?
  motherMiddleName   String?
  motherLastName     String?
  motherId           String?
  education          String?
  occupationType     String?
  occupationLocation String?
  gender             String
  maritalStatus      String
  status             FamilyStatus @default(PENDING)
  createdBy          String?      @map("created_by")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  children           Child[]
  fatherPerson       Person?      @relation("FatherPerson", fields: [fatherId], references: [id])
  headPerson         Person?      @relation("HeadPerson", fields: [headPersonId], references: [id])
  motherPerson       Person?      @relation("MotherPerson", fields: [motherId], references: [id])
  user               User         @relation(fields: [userId], references: [id])
  spouse             Spouse?

  @@index([userId])
  @@index([status])
  @@index([headPersonId])
  @@index([fatherId])
  @@index([motherId])
  @@map("families")
}

model Spouse {
  id                 String   @id @default(cuid())
  familyId           String   @unique
  firstName          String
  middleName         String?
  lastName           String
  fatherFirstName    String?
  fatherMiddleName   String?
  fatherLastName     String?
  motherFirstName    String?
  motherMiddleName   String?
  motherLastName     String?
  personId           String?  @unique
  isDeceased         Boolean  @default(false)
  education          String?
  occupationType     String?
  occupationLocation String?
  gender             String
  createdAt          DateTime @default(now())
  family             Family   @relation(fields: [familyId], references: [id])
  person             Person?  @relation(fields: [personId], references: [id])

  @@index([familyId])
  @@index([personId])
  @@map("spouses")
}

model Child {
  id         String   @id @default(cuid())
  familyId   String
  firstName  String
  middleName String?
  lastName   String
  personId   String?  @unique
  gender     String
  education  String?
  createdAt  DateTime @default(now())
  family     Family   @relation(fields: [familyId], references: [id])
  person     Person?  @relation(fields: [personId], references: [id])

  @@index([familyId])
  @@index([personId])
  @@map("children")
}

model Post {
  id            String    @id @default(cuid())
  userId        String
  title         String
  description   String?
  imageUrl      String?
  location      String?
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  comments      Comment[]
  likes         Like[]
  user          User      @relation(fields: [userId], references: [id])

  @@map("posts")
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  content   String
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  post      Post      @relation(fields: [postId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, postId, parentId])
  @@map("comments")
}

model Like {
  id     String @id @default(cuid())
  userId String
  postId String
  post   Post   @relation(fields: [postId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
  @@map("likes")
}

model LearnFolder {
  id            String        @id @default(cuid())
  name          String
  description   String?
  parentId      String?
  order         Int           @default(0)
  createdBy     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdByUser User?         @relation(fields: [createdBy], references: [id])
  parent        LearnFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children      LearnFolder[] @relation("FolderHierarchy")
  posts         LearnPost[]

  @@index([parentId])
  @@map("learn_folders")
}

model LearnPost {
  id            String      @id @default(cuid())
  title         String
  content       String
  folderId      String
  order         Int         @default(0)
  isPublished   Boolean     @default(true)
  createdBy     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  createdByUser User?       @relation(fields: [createdBy], references: [id])
  folder        LearnFolder @relation(fields: [folderId], references: [id])

  @@index([folderId])
  @@index([order])
  @@map("learn_posts")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
  @@map("email_verifications")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([email, token, expiresAt])
  @@map("password_reset_tokens")
}

enum Role {
  USER
  VERIFIER
  ADMIN
}

enum FamilyStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum RelationType {
  FATHER
  MOTHER
}
