# Database (Neon Postgres connection string)
DATABASE_URL="postgresql://username:password@hostname/neondb?connection_limit=10"

# NextAuth
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-a-secure-secret"

# Google OAuth
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Service (Resend)
# Get API key from https://resend.com
RESEND_API_KEY="re_your_resend_api_key"
RESEND_EMAIL_FROM="noreply@yourdomain.com"

# App
NEXT_PUBLIC_APP_NAME="Caste Community Portal"
